<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardPreventCornerOverlap="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#F8FAFB">

            <TextView
                android:id="@+id/textNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del Profesor"
                android:textColor="#003A5D"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMateria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Materia: Cálculo Integral"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:background="#D4AF37" />

            <TextView
                android:id="@+id/txtHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07:00 AM - 08:00 AM"
                android:textColor="#003A5D"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutExpandable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marcar Estatus:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <RadioButton
                    android:id="@+id/radioAsistencia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Asist."
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:buttonTint="#2ECC71"/>

                <RadioButton
                    android:id="@+id/radioRetardo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Retar."
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:buttonTint="#F1C40F"/>

                <RadioButton
                    android:id="@+id/radioFalta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Falta"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:buttonTint="#E74C3C"/>
            </RadioGroup>

            <EditText
                android:id="@+id/editObservaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Agregar observación (opcional)..."
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Escanear QR / Confirmar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="#003A5D"
                android:enabled="false"
                android:padding="12dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>