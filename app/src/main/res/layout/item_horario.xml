<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="Profesor"
                android:textStyle="bold"
                android:textColor="#000"/>

            <TextView
                android:id="@+id/txtAsignatura"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="Materia"
                android:textColor="#333"/>

            <TextView
                android:id="@+id/txtGrupo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Grupo"
                android:textColor="#333"/>

            <TextView
                android:id="@+id/txtHorario"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="08:00 - 08:40"
                android:textColor="#333"/>
        </LinearLayout>

        <!-- PANEL OPCIONES: SIEMPRE VISIBLE -->
        <LinearLayout
            android:id="@+id/panelOpciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/btnFalta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F"/>

            <CheckBox
                android:id="@+id/btnRetardo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R"
                android:layout_marginStart="12dp"/>

            <CheckBox
                android:id="@+id/btnAsistencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:layout_marginStart="12dp"/>

            <!-- Botones de firma, arrancan ocultos -->
            <ImageButton
                android:id="@+id/btnFirmarMaestro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_firma_maestro"
                android:contentDescription="Firmar Maestro"
                android:background="@android:color/transparent"
                android:visibility="gone"
                android:layout_marginStart="24dp"/>

            <ImageButton
                android:id="@+id/btnFirmarJefe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_firma_jefe"
                android:contentDescription="Firmar Jefe"
                android:background="@android:color/transparent"
                android:visibility="gone"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- PANEL OBSERVACIONES (oculto hasta retardo/falta) -->
        <LinearLayout
            android:id="@+id/panelObservaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtTituloObservaciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observaciones:"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/editObservacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:enabled="false"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
