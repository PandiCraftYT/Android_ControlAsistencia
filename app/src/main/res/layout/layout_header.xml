<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="0dp"
    tools:context=".MainActivity">

    <!-- ENCABEZADO -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/encabezadoLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#E0E0E0"
        android:padding="8dp"
        android:elevation="4dp">

        <!-- Logo UAS -->
        <ImageView
            android:id="@+id/logoUAS"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/logouas"
            android:contentDescription="Logo UAS"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/tituloApp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Control de Asistencia"
            android:textSize="20sp"
            android:textColor="#343C6A"
            android:textStyle="bold"
            android:gravity="center_vertical"
            app:layout_constraintStart_toEndOf="@id/logoUAS"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/relojHora"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_weight="2"/>

        <!-- Reloj en vivo -->
        <TextView
            android:id="@+id/relojHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="22sp"
            android:textColor="#000"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
