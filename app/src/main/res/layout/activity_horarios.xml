<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- ENCABEZADO -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/encabezadoLayout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/logoUAS"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logouas"
            android:contentDescription="Logo UAS"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="12dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/logoUAS"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UAS"
                android:textSize="18sp"
                android:textColor="#0D47A1"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASISTENCIA"
                android:textSize="12sp"
                android:textColor="#757575"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <TextView
            android:id="@+id/relojHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_circle_button"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="12dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- INFO ZONA Y GRUPO -->
    <TextView
        android:id="@+id/textViewZonaGrupo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Horarios"
        android:textSize="16sp"
        android:textColor="#1A237E"
        android:textStyle="bold"
        android:background="#FFFFFF"
        android:elevation="2dp"/>

    <!-- BOTÓN ATRÁS -->
    <LinearLayout
        android:id="@+id/btnAtras"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_margin="8dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/flecha"
            app:tint="#0D47A1"
            android:contentDescription="Icono Atrás"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGRESAR"
            android:textColor="#0D47A1"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/horariosRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>